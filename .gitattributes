# Git attributes file for helloMocker project
# Forces LF line endings for all text files to maintain consistency across platforms

# Source code files
*.java text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.properties text eol=lf

# Documentation files
*.md text eol=lf
*.txt text eol=lf

# Build and configuration files
pom.xml text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Scripts
*.sh text eol=lf
*.bat text eol=crlf

# Binary files (do not modify)
*.jar binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary